# Telegram
BOT_TOKEN=your-bot-token-from-BotFather
ADMIN_TELEGRAM_IDS=123456789,987654321
# Support Telegram usernames (comma-separated, no @) — shown as Admin 1, Admin 2 buttons
ADMIN_ACCOUNTS=admin_username,admin2_username
# AirVPN Payments Proofs group chat id (negative number, bot must be admin)
PAYMENTS_PROOFS_GROUP_ID=-1001234567890

# Environment: production | development
ENV=production
# Set true only for local dev without a VPS (generates mock VLESS keys)
DEV_MOCK_VPN=false

# Database (optional, default: ./airvpn.sqlite3)
# SQLITE_PATH=/path/to/airvpn.sqlite3

# ─── VPN servers (buy flow: Choose Server → Choose Plan) ─────────────────────
# Comma-separated server IDs in chooser order. Add more: VPN_SERVERS=sg,jp,us
VPN_SERVERS=sg

# ─── Server: Singapore (sg) ───────────────────────────────────────────────────
VPN_SERVER_sg_NAME=Singapore
VPN_SERVER_sg_NAME_MY=စင်္ကာပူ
VPN_SERVER_sg_PANEL_URL=
VPN_SERVER_sg_PANEL_USERNAME=admin
VPN_SERVER_sg_PANEL_PASSWORD=your-panel-password
VPN_SERVER_sg_PANEL_INBOUND_ID=1
VPN_SERVER_sg_PANEL_VERIFY_SSL=true
VPN_SERVER_sg_VPS_HOST=your-vps-ip-or-domain
VPN_SERVER_sg_VPS_PORT=443
VPN_SERVER_sg_VLESS_SECURITY=reality
VPN_SERVER_sg_VLESS_FLOW=xtls-rprx-vision
VPN_SERVER_sg_VLESS_SNI=www.microsoft.com
VPN_SERVER_sg_VLESS_FP=chrome
VPN_SERVER_sg_VLESS_PBK=your-reality-public-key
VPN_SERVER_sg_VLESS_SID=04f890
VPN_SERVER_sg_VLESS_SPX=/

# Plans per server: title|data_gb|price_ks|duration_days|sort_order
# Use "unlimited" for duration_days on unlimited-date plans (or a day count)
# Separate plans with ;
VPN_SERVER_sg_PLANS=50 GB - 30 Days|50|2500|30|1;100 GB - 30 Days|100|4000|30|2;100 GB - Unlimited Date|100|6000|unlimited|3;300 GB - Unlimited Date|300|15000|unlimited|4;1 TB - Unlimited Date|1024|40000|unlimited|5

# Example second server (uncomment VPN_SERVERS=sg,jp and fill in):
# VPN_SERVER_jp_NAME=Japan
# VPN_SERVER_jp_NAME_MY=ဂျပန်
# VPN_SERVER_jp_PANEL_URL=https://jp.example.com:2053/xxx
# VPN_SERVER_jp_PANEL_USERNAME=admin
# VPN_SERVER_jp_PANEL_PASSWORD=secret
# VPN_SERVER_jp_PANEL_INBOUND_ID=1
# VPN_SERVER_jp_VPS_HOST=jp.example.com
# VPN_SERVER_jp_VPS_PORT=443
# VPN_SERVER_jp_VLESS_PBK=...
# VPN_SERVER_jp_PLANS=50 GB - 30 Days|50|3000|30|1

# Legacy single-server vars (fallback for sg when VPN_SERVER_sg_* is empty)
PANEL_URL=
PANEL_USERNAME=admin
PANEL_PASSWORD=your-panel-password
PANEL_INBOUND_ID=1
PANEL_VERIFY_SSL=true
VPS_HOST=your-vps-ip-or-domain
VPS_PORT=443
VLESS_SECURITY=reality
VLESS_FLOW=xtls-rprx-vision
VLESS_SNI=www.microsoft.com
VLESS_FP=chrome
VLESS_PBK=your-reality-public-key
VLESS_SID=04f890
VLESS_SPX=/

# Paid plans marked "Unlimited Date" use this subscription length (~100 years)
UNLIMITED_PLAN_DAYS=36500

# Daily gift
DAILY_GIFT_MB=500
DAILY_STREAK_BONUS_MB=10
MAX_DAILY_STREAK=7
FREE_SUB_EXPIRY_DAYS=1
# Server ID for daily-gift free keys (must be in VPN_SERVERS)
FREE_KEYS_LOCATION=sg

# Per-user VPN subscription URL (v2rayNG / Hiddify — shows data left + expiry in app)
# Coolify/Docker: expose port 8080 and point a domain here (no trailing slash)
# SUB_PUBLIC_BASE_URL=https://sub.yourdomain.com
# SUB_SERVER_HOST=0.0.0.0
# SUB_SERVER_PORT=8080
# Docker/Coolify paths:
# SQLITE_PATH=/data/airvpn.sqlite3
# KBZ_SESSION_PATH=/data/kbz_session.json

# KBZPay auto-verify (copy kbz_session.example.json → kbz_session.json)
KBZ_AUTO_VERIFY=true
KBZ_SESSION_PATH=kbz_session.json
KBZ_MERCHANT_NAME=Your Merchant Name
KBZ_MERCHANT_PHONE=09xxxxxxxxx

# Auto-reject KBZPay receipts when the transfer is older than this (hours)
PAYMENT_TX_MAX_AGE_HOURS=1

# Rate limits (per Telegram user)
RATE_DAILY_CLAIM_PER_DAY=1
RATE_PAYMENT_PER_HOUR=5
RATE_KBZ_VERIFY_PER_HOUR=10
RATE_RECEIPT_SCREENSHOT_PER_MIN=2

# VPN app download links — Play Store / App Store (optional overrides)
# VPN_ANDROID_V2RAYNG=https://play.google.com/store/apps/details?id=com.v2ray.ang
# VPN_ANDROID_HIDDIFY=https://play.google.com/store/apps/details?id=app.hiddify.com
# VPN_IOS_STREISAND=https://apps.apple.com/app/streisand/id6450534064
# VPN_IOS_HIDDIFY=https://apps.apple.com/app/hiddify-proxy-vpn/id6594873375
